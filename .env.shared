# Override env for the shared-Postgres compose variant.
# Use with:
#   docker compose --env-file .env.shared \
#       -f compose.databases.shared.yaml \
#       -f compose.services.yaml up
#
# (or compose.modulith.yaml in place of compose.services.yaml)
#
# Without these overrides, compose.services.yaml / compose.modulith.yaml
# default to per-service Postgres containers (auth-db/geo-db/activity-db)
# defined in compose.yaml. With them, all three modules talk to the single
# `shared-db` instance from compose.databases.shared.yaml.

AUTH_DB_HOST=shared-db
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth
AUTH_DB_DEPENDS_ON=shared-db

GEO_DB_HOST=shared-db
GEO_DB_PORT=5432
GEO_DB_NAME=geo
GEO_DB_DEPENDS_ON=shared-db

ACTIVITY_DB_HOST=shared-db
ACTIVITY_DB_PORT=5432
ACTIVITY_DB_NAME=activity
ACTIVITY_DB_DEPENDS_ON=shared-db

DB_USER=postgres
DB_PASSWORD=yourpassword
