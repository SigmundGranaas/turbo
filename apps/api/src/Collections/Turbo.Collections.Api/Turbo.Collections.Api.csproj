<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Turboapi.Collections</RootNamespace>
    <Version>0.1.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Medo.Uuid7" />
    <PackageReference Include="OpenTelemetry.Instrumentation.EntityFrameworkCore" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Turbo.Collections.Core\Turbo.Collections.Core.csproj" />
    <ProjectReference Include="..\Turbo.Collections.Contracts\Turbo.Collections.Contracts.csproj" />
    <ProjectReference Include="..\Turbo.Collections.Infrastructure\Turbo.Collections.Infrastructure.csproj" />
    <!-- For wiring IAccessControl + SharingReadContext in the modulith. The
         standalone Collections host registers its own access-control adapter
         instead of pulling Sharing.Infrastructure in. -->
    <ProjectReference Include="..\..\Sharing\Turbo.Sharing.Infrastructure\Turbo.Sharing.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Shared\Turbo.Messaging.Nats\Turbo.Messaging.Nats.csproj" />
    <ProjectReference Include="..\..\..\TurboAuthentication\TurboAuthentication.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.AspNetCore.Builder" />
    <Using Include="Microsoft.AspNetCore.Hosting" />
    <Using Include="Microsoft.AspNetCore.Http" />
    <Using Include="Microsoft.AspNetCore.Routing" />
    <Using Include="Microsoft.Extensions.Configuration" />
    <Using Include="Microsoft.Extensions.DependencyInjection" />
    <Using Include="Microsoft.Extensions.Hosting" />
    <Using Include="Microsoft.Extensions.Logging" />
  </ItemGroup>

</Project>
