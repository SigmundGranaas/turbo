{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.DataProtection": "Error"
    }
  },
  "AllowedHosts": "*",
  "Topology": "Microservices",
  "ReverseProxy": {
    "Microservices": {
      "Routes": {
        "auth-route": {
          "ClusterId": "auth-cluster",
          "Match": { "Path": "/api/auth/{**catch-all}" }
        },
        "geo-route": {
          "ClusterId": "geo-cluster",
          "Match": { "Path": "/api/geo/{**catch-all}" }
        },
        "tracks-route": {
          "ClusterId": "tracks-cluster",
          "Match": { "Path": "/api/tracks/{**catch-all}" }
        },
        "collections-route": {
          "ClusterId": "collections-cluster",
          "Match": { "Path": "/api/collections/{**catch-all}" }
        },
        "sharing-route": {
          "ClusterId": "sharing-cluster",
          "Match": { "Path": "/api/sharing/{**catch-all}" }
        },
        "activities-route": {
          "ClusterId": "activities-cluster",
          "Match": { "Path": "/api/activities/{**catch-all}" }
        },
        "tiles-public-route": {
          "ClusterId": "tileserver-cluster",
          "Match": { "Path": "/api/tiles/{**catch-all}" },
          "Transforms": [
            { "PathRemovePrefix": "/api/tiles" }
          ]
        },
        "route-route": {
          "ClusterId": "tileserver-cluster",
          "Match": { "Path": "/api/route/{**catch-all}" },
          "Transforms": [
            { "PathRemovePrefix": "/api/route" },
            { "PathPrefix": "/v1/route" }
          ]
        },
        "tiles-admin-route": {
          "ClusterId": "tileserver-cluster",
          "Match": { "Path": "/api/tiles-admin/{**catch-all}" },
          "Transforms": [
            { "PathRemovePrefix": "/api/tiles-admin" },
            { "PathPrefix": "/admin" }
          ]
        }
      },
      "Clusters": {
        "auth-cluster": {
          "Destinations": { "destination1": { "Address": "http://auth:8080" } }
        },
        "geo-cluster": {
          "Destinations": { "destination1": { "Address": "http://geo:8080" } }
        },
        "tracks-cluster": {
          "Destinations": { "destination1": { "Address": "http://tracks:8080" } }
        },
        "collections-cluster": {
          "Destinations": { "destination1": { "Address": "http://collections:8080" } }
        },
        "sharing-cluster": {
          "Destinations": { "destination1": { "Address": "http://sharing:8080" } }
        },
        "activities-cluster": {
          "Destinations": { "destination1": { "Address": "http://activities:8080" } }
        },
        "tileserver-cluster": {
          "Destinations": { "destination1": { "Address": "http://tileserver:8080" } }
        }
      }
    },
    "Modulith": {
      "Routes": {
        "auth-route": {
          "ClusterId": "modulith-cluster",
          "Match": { "Path": "/api/auth/{**catch-all}" }
        },
        "geo-route": {
          "ClusterId": "modulith-cluster",
          "Match": { "Path": "/api/geo/{**catch-all}" }
        },
        "tracks-route": {
          "ClusterId": "modulith-cluster",
          "Match": { "Path": "/api/tracks/{**catch-all}" }
        },
        "collections-route": {
          "ClusterId": "modulith-cluster",
          "Match": { "Path": "/api/collections/{**catch-all}" }
        },
        "sharing-route": {
          "ClusterId": "modulith-cluster",
          "Match": { "Path": "/api/sharing/{**catch-all}" }
        },
        "activities-route": {
          "ClusterId": "modulith-cluster",
          "Match": { "Path": "/api/activities/{**catch-all}" }
        },
        "tiles-public-route": {
          "ClusterId": "tileserver-cluster",
          "Match": { "Path": "/api/tiles/{**catch-all}" },
          "Transforms": [
            { "PathRemovePrefix": "/api/tiles" }
          ]
        },
        "route-route": {
          "ClusterId": "tileserver-cluster",
          "Match": { "Path": "/api/route/{**catch-all}" },
          "Transforms": [
            { "PathRemovePrefix": "/api/route" },
            { "PathPrefix": "/v1/route" }
          ]
        },
        "tiles-admin-route": {
          "ClusterId": "tileserver-cluster",
          "Match": { "Path": "/api/tiles-admin/{**catch-all}" },
          "Transforms": [
            { "PathRemovePrefix": "/api/tiles-admin" },
            { "PathPrefix": "/admin" }
          ]
        }
      },
      "Clusters": {
        "modulith-cluster": {
          "Destinations": { "destination1": { "Address": "http://modulith:8080" } }
        },
        "tileserver-cluster": {
          "Destinations": { "destination1": { "Address": "http://tileserver:8080" } }
        }
      }
    }
  }
}
