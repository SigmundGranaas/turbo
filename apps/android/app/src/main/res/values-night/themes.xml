<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TurboExpressive" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/turbo_surface_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.TurboExpressive.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/turbo_surface_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.TurboExpressive</item>
    </style>
</resources>
