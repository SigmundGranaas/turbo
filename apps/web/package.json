{
  "name": "@turbo/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Native web app for Turbo — React + the turbomap wgpu renderer (WASM). Replaces the Flutter app.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "wasm": "../turbomap/crates/turbomap-web/build.sh",
    "wasm:release": "../turbomap/crates/turbomap-web/build.sh --release",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "turbomap-web": "file:../turbomap/crates/turbomap-web/pkg",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  }
}
