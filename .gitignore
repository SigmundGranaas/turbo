# Repo-wide ignores. App-specific ignores live in apps/<app>/.gitignore.

# OS
.DS_Store
Thumbs.db

# Editors / IDEs (cross-cutting)
.idea/
.vscode/
*.iml
*.swp
*.swo

# Build / log scratch
*.log

# Environment files (never commit secrets)
.env
.env.local
.env.development
.env.production
*.env
!infra/env/.env.shared

# Docker / compose scratch
infra/compose/data/

# Stray Flutter scaffolding. Flutter scaffolds these under whatever cwd it
# runs from; guard against tools accidentally running `flutter` at the repo
# root. `apps/flutter/` was removed in P5.3 (web + Android are the product) —
# a stray `flutter pub get` (e.g. a startup hook) resurrects it as build
# scratch, so it is ignored here to keep it out of commits.
/.dart_tool/
/.flutter-plugins
/.flutter-plugins-dependencies
/android/
/ios/
/linux/
/macos/
/windows/
/web/
/build/
/apps/flutter/
