# Repo-wide ignores. App-specific ignores live in apps/<app>/.gitignore.

# OS
.DS_Store
Thumbs.db

# Editors / IDEs (cross-cutting)
.idea/
.vscode/
*.iml
*.swp
*.swo

# Build / log scratch
*.log

# Environment files (never commit secrets)
.env
.env.local
.env.development
.env.production
*.env
!infra/env/.env.shared

# Docker / compose scratch
infra/compose/data/

# Root-level Flutter scaffolding generated by tooling running in the wrong
# directory. The real Flutter project lives under apps/flutter/; nothing
# Flutter-shaped belongs at the repo root.
/.dart_tool/
/.flutter-plugins
/.flutter-plugins-dependencies
/android/
/ios/
/linux/
/macos/
/windows/
/web/
/build/
