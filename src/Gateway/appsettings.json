{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Topology": "Microservices",
  "ReverseProxy": {
    "Microservices": {
      "Routes": {
        "auth-route": {
          "ClusterId": "auth-cluster",
          "Match": { "Path": "/api/auth/{**catch-all}" }
        },
        "geo-route": {
          "ClusterId": "geo-cluster",
          "Match": { "Path": "/api/geo/{**catch-all}" }
        },
        "activity-route": {
          "ClusterId": "activity-cluster",
          "Match": { "Path": "/api/activity/{**catch-all}" }
        }
      },
      "Clusters": {
        "auth-cluster": {
          "Destinations": { "destination1": { "Address": "http://auth:8080" } }
        },
        "geo-cluster": {
          "Destinations": { "destination1": { "Address": "http://geo:8080" } }
        },
        "activity-cluster": {
          "Destinations": { "destination1": { "Address": "http://activity:8080" } }
        }
      }
    },
    "Modulith": {
      "Routes": {
        "auth-route": {
          "ClusterId": "modulith-cluster",
          "Match": { "Path": "/api/auth/{**catch-all}" }
        },
        "geo-route": {
          "ClusterId": "modulith-cluster",
          "Match": { "Path": "/api/geo/{**catch-all}" }
        },
        "activity-route": {
          "ClusterId": "modulith-cluster",
          "Match": { "Path": "/api/activity/{**catch-all}" }
        }
      },
      "Clusters": {
        "modulith-cluster": {
          "Destinations": { "destination1": { "Address": "http://modulith:8080" } }
        }
      }
    }
  }
}
