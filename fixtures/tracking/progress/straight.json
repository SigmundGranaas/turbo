{
  "name": "straight",
  "description": "A 0.04deg east-west line at the equator (~4448 m). Fixes walk it end to end; fraction is the simple proportion, arrived only at the final point.",
  "params": { "windowBackM": 60, "windowAheadM": 400, "offRouteM": 50, "arriveEndM": 30 },
  "route": [[0.0, 0.0], [0.0, 0.04]],
  "fixes": [
    [0.0, 0.0],
    [0.0, 0.01],
    [0.0, 0.02],
    [0.0, 0.03],
    [0.0, 0.04]
  ],
  "expect": [
    { "fraction": 0.0,  "arrived": false, "offRoute": false },
    { "fraction": 0.25, "arrived": false, "offRoute": false },
    { "fraction": 0.5,  "arrived": false, "offRoute": false },
    { "fraction": 0.75, "arrived": false, "offRoute": false },
    { "fraction": 1.0,  "arrived": true,  "offRoute": false }
  ]
}
