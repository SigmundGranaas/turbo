        { "name": "", "kind": "Haug", "distance_m": 35.0, "status": "aktiv" }
      ],
      "kommune": { "name": "Bodø", "fylke": "Nordland" }
    },
    "expect": { "title": "Bodø", "secondary": "Nordland", "kommune": "Bodø" }
  },
  {
    "name": "named neighbour beats a closer nameless feature",
