      "toponyms": [
        { "name": "", "kind": "Haug", "distance_m": 5.0, "status": "aktiv" },
        { "name": "Galdhøpiggen", "kind": "Fjelltopp", "distance_m": 55.0, "status": "aktiv" }
      ]
    },
    "expect": { "title": "Galdhøpiggen", "qualifier": "on", "distance_m": 55.0 }
  },
  {
