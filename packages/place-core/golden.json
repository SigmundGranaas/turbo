[
  {
    "name": "peak within 100 m is tagged On and beats far peaks/towns",
    "input": {
      "toponyms": [
        { "name": "Galdhøpiggen", "kind": "Fjelltopp", "distance_m": 33.0, "status": "aktiv" },
        { "name": "Spiterhøi", "kind": "Fjelltopp", "distance_m": 7000.0, "status": "aktiv" },
        { "name": "Lom", "kind": "Tettsted", "distance_m": 25000.0, "status": "aktiv" }
      ]
    },
    "expect": { "title": "Galdhøpiggen", "qualifier": "on", "distance_m": 33.0 }
  },
  {
    "name": "peak within 800 m is CloseTo; out-of-range peak ignored",
    "input": {
      "toponyms": [
        { "name": "Storrist", "kind": "Fjelltopp", "distance_m": 450.0, "status": "aktiv" },
        { "name": "Lomseggen", "kind": "Ås", "distance_m": 5000.0, "status": "aktiv" }
      ]
    },
    "expect": { "title": "Storrist", "qualifier": "closeTo", "distance_m": 450.0 }
  },
  {
    "name": "protected area wins when no usable toponym; kommune enriches subtitle",
    "input": {
      "toponyms": [],
      "protected_area": { "name": "Saltfjellet–Svartisen nasjonalpark", "kind": "Nasjonalpark" },
      "kommune": { "name": "Bodø", "fylke": "Nordland" }
    },
    "expect": {
      "title": "Saltfjellet–Svartisen nasjonalpark",
      "qualifier": "inArea",
      "secondary": "Nasjonalpark",
      "kommune": "Bodø",
      "fylke": "Nordland"
    }
  },
  {
    "name": "tight toponym bypasses a containing protected area",
