    },
    "expect": { "title": "Lom", "secondary": "Innlandet", "kommune": "Lom" }
  },
  {
    "name": "status penalty: a live peak beats a closer historic peak",
    "input": {
      "toponyms": [
        { "name": "Peak A", "kind": "Fjelltopp", "distance_m": 90.0, "status": "historisk" },
        { "name": "Peak B", "kind": "Fjelltopp", "distance_m": 95.0, "status": "aktiv" }
      ]
